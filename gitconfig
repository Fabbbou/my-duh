[alias]
	b = !git for-each-ref --sort=-committerdate --format='%(refname:short) %(objectname:short)' refs/heads/ | head -n 10 
	ball = !git for-each-ref --sort=-committerdate --format='%(committerdate:relative) %(refname:short)' refs/heads/
	c = commit
	ca = commit --amend
	cc = checkout
	l = log -n 4 --pretty=oneline
	la = log --pretty=oneline
	p = push -u origin HEAD
	pr = request-pull
	pt = push -u origin HEAD --tags
	r1 = reset --soft HEAD~1
	s = status
	squash-all = "!f(){ git reset $(git commit-tree HEAD^{tree} \"$@\");};f"